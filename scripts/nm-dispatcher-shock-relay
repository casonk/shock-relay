#!/bin/bash
# NetworkManager dispatcher: drain shock-relay offline queue when network comes up.
#
# Install:
#   sudo cp scripts/nm-dispatcher-shock-relay /etc/NetworkManager/dispatcher.d/50-shock-relay-drain
#   sudo chmod 755 /etc/NetworkManager/dispatcher.d/50-shock-relay-drain
#
# Set SHOCK_RELAY_ROOT in the dispatcher environment or edit this local copy.

INTERFACE="$1"
STATUS="$2"

[ "$STATUS" = "up" ] || exit 0

SHOCK_RELAY_ROOT="${SHOCK_RELAY_ROOT:-}"
[ -n "$SHOCK_RELAY_ROOT" ] || exit 0
DRAIN_SCRIPT="$SHOCK_RELAY_ROOT/scripts/drain_queue.py"

[ -f "$DRAIN_SCRIPT" ] || exit 0

# Run as the desktop user (NM dispatcher runs as root).
DESKTOP_USER="$(logname 2>/dev/null || who | awk 'NR==1{print $1}')"
if [ -n "$DESKTOP_USER" ]; then
    su -l "$DESKTOP_USER" -c "python3 '$DRAIN_SCRIPT'" &
else
    python3 "$DRAIN_SCRIPT" &
fi
